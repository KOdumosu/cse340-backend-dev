<%- include('partials/header') %>

<main class="form-page">


<section class="form-card">

    <h1>Add New Organization</h1>

    <p class="form-intro">
        Complete the form below to add a new organization to the database.
    </p>

    <% if (errors && errors.length > 0) { %>
        <div class="error-box">
            <h3>Please correct the following:</h3>
            <ul>
                <% errors.forEach(error => { %>
                    <li><%= error %></li>
                <% }) %>
            </ul>
        </div>
    <% } %>

    <form
        action="/new-organization"
        method="POST"
        class="organization-form"
    >

        <div class="form-group">
            <label for="name">
                Organization Name <span class="required">*</span>
            </label>

            <input
                type="text"
                id="name"
                name="name"
                value="<%= typeof name !== 'undefined' ? name : '' %>"
                required
                maxlength="150"
            >
        </div>

        <div class="form-group">
            <label for="description">
                Description <span class="required">*</span>
            </label>

            <textarea
                id="description"
                name="description"
                rows="6"
                required
            ><%= typeof description !== 'undefined' ? description : '' %></textarea>
        </div>

        <div class="form-group">
            <label for="contact_email">
                Contact Email <span class="required">*</span>
            </label>

            <input
                type="email"
                id="contact_email"
                name="contact_email"
                value="<%= typeof contact_email !== 'undefined' ? contact_email : '' %>"
                required
            >
        </div>

        <div class="form-group">
            <label for="logo_filename">
                Logo Filename <span class="required">*</span>
            </label>

            <input
                type="text"
                id="logo_filename"
                name="logo_filename"
                value="<%= typeof logo_filename !== 'undefined' ? logo_filename : '' %>"
                required
            >

            <small class="help-text">
                Example: organization-logo.png
            </small>
        </div>

        <div class="form-buttons">

            <button
                type="submit"
                class="btn-submit"
            >
                Save Organization
            </button>

            <a
                href="/organizations"
                class="btn-cancel"
            >
                Cancel
            </a>

        </div>

    </form>

</section>


</main>

<%- include('partials/footer') %>
