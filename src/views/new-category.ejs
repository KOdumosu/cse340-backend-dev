<h1>Create Category</h1>

<% if (errors && errors.length > 0) { %>
<ul>
  <% errors.forEach(error => { %>
    <li><%= error %></li>
  <% }) %>
</ul>
<% } %>

<form action="/new-category" method="POST">

  <label>
    Category Name
  </label>

  <input
    type="text"
    name="category_name"
    maxlength="100"
    required
    value="<%= category_name || '' %>"
  >

  <button type="submit">
    Create Category
  </button>

</form>