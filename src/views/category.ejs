<%- include('partials/header') %>

<main>
    <h1><%= category.category_name %></h1>

    <h2>Projects in this Category</h2>

    <ul>
        <% projects.forEach(project => { %>
            <li>
                <a href="/project/<%= project.project_id %>">
                    <%= project.project_name %>
                </a>
            </li>
        <% }) %>
    </ul>
</main>

<%- include('partials/footer') %>